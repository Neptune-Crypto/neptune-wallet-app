{
  "identifier": "default",
  "description": "Hardened permissions for local app data access only",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "dialog:default",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "core:window:allow-start-dragging",
    "core:window:allow-start-resize-dragging",
    "core:window:allow-is-resizable",
    "core:window:allow-set-resizable",
    "core:window:allow-close",
    "core:window:allow-center",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-set-size",
    "core:window:allow-set-focus",
    "core:window:allow-is-maximized",
    "core:window:allow-toggle-maximize",
    "updater:default",
    "process:allow-restart",
    "fs:default",
    {
      "identifier": "fs:allow-app-write-recursive",
      "scope": ["$APP_CONFIG/**", "$APP_DATA/**"]
    },
    {
      "identifier": "fs:allow-app-read-recursive",
      "scope": ["$APP_CONFIG/**", "$APP_DATA/**"]
    },
    {
      "identifier": "fs:allow-exists",
      "scope": ["$APP_CONFIG/**", "$APP_DATA/**"]
    },
    {
      "identifier": "fs:allow-read-dir",
      "scope": ["$APP_CONFIG/**", "$APP_DATA/**"]
    },
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://github.com/Neptune-Crypto/neptune-wallet-app/*"
        }
      ]
    },
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "https://api.github.com/repos/Neptune-Crypto/neptune-wallet-app/releases/latest"
        }
      ]
    },
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "scope": ["$APP_CONFIG/**", "$APP_DATA/**"]
    },
    "process:default"
  ]
}
