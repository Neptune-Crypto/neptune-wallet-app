{
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../build",
    "devUrl": "http://localhost:3001"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Finance",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15.0"
    },
    "externalBin": [],
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "productName": "NeptuneWallet",
  "mainBinaryName": "NeptuneWallet",
  "identifier": "org.neptunefundamentals.wallet",
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1NEIyN0YzMzE1MjlFRTgKUldUb25sSXg4eWRMeGJrWUNFLzErSXprK1h5alFFbmFoN2FhMmR0d0h2OW4rRnV3OXJtYVlJeXUK",
      "endpoints": [
        "https://github.com/Neptune-Crypto/neptune-wallet-app/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self' *.localhost 127.0.0.1; connect-src 'self' http://127.0.0.1:* *.localhost; style-src 'self' 'unsafe-inline'"
    },
    "macOSPrivateApi": false
  }
}
